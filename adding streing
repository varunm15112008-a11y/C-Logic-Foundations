#include <iostream>
using namespace std;

int main()
{
	string name1,name2;
	cout<<"enter your name1: ";
	cin>>name1;
	cout<<"enter your name2: ";
	cin>>name2;
	
	int i=0;
	int count=0;
	for (i=0;name1[i] != '\0';i++)
	 {
	 	count++;
	 }
	 
	 int count2=0;
	 for (i=0;name2[i] != '\0';i++)
	 {
	 	count2++;
	 }
	 
	 name1.resize(count+count2);
	 
	 for (i=0;i<count;i++)
	 {
	 	name1[i]=name1[i];
	 }
    
	for (i=0;i<count;i++)
	{
		name1[count+i]=name2[i];
	}
	cout<<name1;
}
